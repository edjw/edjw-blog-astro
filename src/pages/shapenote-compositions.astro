---
import compositionsManifest from "@/data/shapenote-compositions.json";
import PageLayout from "@/layouts/PageLayout.astro";
import { titleCase } from "title-case";

const title = "Shapenote Compositions";
const socialDescription = "Ed Johnson-Williams' shapenote compositions";

interface CompositionPdf {
  name: string;
  url: string;
  compositionMonth: string;
}

interface MonthGroup {
  month: string;
  compositions: CompositionPdf[];
}

interface YearGroup {
  year: string;
  months: MonthGroup[];
}

const monthFormatter = new Intl.DateTimeFormat("en-GB", { month: "long" });

function monthName(compositionMonth: string): string {
  const [year, month] = compositionMonth.split("-").map(Number);
  return monthFormatter.format(new Date(Date.UTC(year!, month! - 1)));
}

function groupCompositions(compositions: CompositionPdf[]): YearGroup[] {
  const yearGroups: YearGroup[] = [];

  for (const composition of compositions) {
    const year = composition.compositionMonth.slice(0, 4);
    const month = monthName(composition.compositionMonth);
    let yearGroup = yearGroups.at(-1);

    if (yearGroup?.year !== year) {
      yearGroup = { year, months: [] };
      yearGroups.push(yearGroup);
    }

    let monthGroup = yearGroup.months.at(-1);
    if (monthGroup?.month !== month) {
      monthGroup = { month, compositions: [] };
      yearGroup.months.push(monthGroup);
    }

    monthGroup.compositions.push(composition);
  }

  return yearGroups;
}

const compositionGroups = groupCompositions(compositionsManifest);
---

<PageLayout title={title} socialDescription={socialDescription}>
  <p>
    These are my <a href="https://en.wikipedia.org/wiki/Shape_note">shapenote</a
    >
    compositions, with the newest composition dates first. You can get the <a
      href="https://github.com/edjw/shapenote-compositions/tree/main/compositions/finished"
      >Lilypond files here</a
    >.
  </p>

  <div class="mt-6 flex flex-col gap-4">
    {
      compositionGroups.map((yearGroup, yearIndex) => (
        <section class={yearIndex === 0 ? undefined : "mt-12"}>
          <h2 class="mb-4 text-3xl font-bold text-[#DA291C]">
            {yearGroup.year}
          </h2>

          {yearGroup.months.map((monthGroup, monthIndex) => (
            <section class={monthIndex === 0 ? undefined : "mt-8"}>
              <h3 class="mb-3 text-xl font-bold">{monthGroup.month}</h3>

              <ul class="flex list-none flex-col gap-4">
                {monthGroup.compositions.map((composition) => (
                  <li class="flex flex-col gap-0.5 border-l py-2 pl-4">
                    <a
                      href={composition.url}
                      class="font-semibold hover:underline"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {titleCase(composition.name.replace(/-/g, " "))}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </section>
      ))
    }
  </div>
</PageLayout>
